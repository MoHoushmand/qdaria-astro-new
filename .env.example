# Supabase project credentials (copy from dashboard or ../zipminator/web/.env.local)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Cookie domain for cross-subdomain SSO
# Production: .qdaria.com
# Local dev:  leave empty (browsers reject Domain attribute on localhost)
AUTH_COOKIE_DOMAIN=

# Apple Sign-In toggle (requires $99/yr Apple Dev account + Services ID + key)
AUTH_APPLE_ENABLED=false
