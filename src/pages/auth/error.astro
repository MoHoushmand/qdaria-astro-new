---
import BaseLayout from '../../layouts/BaseLayout.astro';

const reason = Astro.url.searchParams.get('reason') ?? 'unknown_error';
const prettyReason = reason.replace(/_/g, ' ');
---

<BaseLayout title="Sign-in error">
  <main class="mx-auto max-w-xl px-4 py-24">
    <h1 class="text-3xl font-semibold mb-4">Sign-in error</h1>
    <p class="text-base text-slate-300 mb-6">
      We could not complete your sign-in. Reason:
    </p>
    <pre class="rounded-lg bg-slate-900/60 border border-slate-700 p-4 text-sm text-amber-300 whitespace-pre-wrap">{prettyReason}</pre>
    <div class="mt-8 flex gap-3">
      <a href="/auth/login" class="inline-flex items-center rounded-md border border-slate-600 px-4 py-2 text-sm hover:bg-slate-800">Try again</a>
      <a href="/" class="inline-flex items-center rounded-md px-4 py-2 text-sm text-slate-300 hover:text-white">Back home</a>
    </div>
  </main>
</BaseLayout>
