---
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteLogoSquare from '@components/SiteLogo/SiteLogoSquare.astro';
import { OAuthButtons } from '@qdaria/auth/components/OAuthButtons';
import { EmailMagicLinkForm } from '@qdaria/auth/components/EmailMagicLinkForm';

const safeNext = (raw: string | null): string => {
  if (!raw) return '/invest/business-plan';
  if (!raw.startsWith('/') || raw.startsWith('//')) return '/invest/business-plan';
  return raw;
};

const next = safeNext(Astro.url.searchParams.get('next'));
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Sign in" description="Sign in to QDaria with Google, GitHub, LinkedIn, Apple, or email">
  <div class="pt-24 md:pt-36">
    <div class="mx-auto flex w-full max-w-md flex-col justify-center gap-6 px-4">
      <SiteLogoSquare />

      <div class="rounded-lg border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h1 class="mb-2 text-center text-2xl font-bold">Sign in</h1>
        <p class="mb-6 text-center text-sm text-gray-600 dark:text-gray-400">
          One account across the QDaria web, mobile, and desktop apps.
        </p>

        {error && (
          <div class="mb-4 rounded-md bg-red-50 p-3 text-sm text-red-800 dark:bg-red-900/20 dark:text-red-400">
            {decodeURIComponent(error)}
          </div>
        )}

        <OAuthButtons
          client:only="react"
          redirectTo={next}
          className="flex flex-col gap-3"
        />

        <div class="my-6 flex items-center gap-3">
          <div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div>
          <span class="text-xs uppercase tracking-wide text-gray-500">or</span>
          <div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div>
        </div>

        <EmailMagicLinkForm client:only="react" redirectTo={next} />

        <p class="mt-6 text-center text-xs text-gray-500 dark:text-gray-400">
          By signing in, you agree to our Terms of Service and Privacy Policy.
        </p>
      </div>

      <p class="text-center text-xs text-gray-500 dark:text-gray-400">
        Admin account? <a href="/login" class="underline hover:text-gray-700 dark:hover:text-gray-300">Use the legacy sign-in</a>.
      </p>
    </div>
  </div>
</BaseLayout>
