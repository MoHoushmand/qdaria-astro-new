---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroSideElectric from "@components/Hero/HeroSideElectric.astro";
import LogoCloudMarquee from "@components/LogoCloud/LogoCloudMarquee.astro";
import BlogCloudMarquee from "@components/Blog/BlogCloudMarquee.astro";
import FeatureCardsSmall from "@components/Feature/FeatureCardsSmall.astro";
import CtaLightning from "@components/Cta/CtaLightning.astro";
import { Image } from "astro:assets";
import lindsayImage from "@assets/images/social-responsibility/ecomoyo/ecomoyo-lindsay-barna0.avif";
import sciartImage from "@assets/images/social-responsibility/sciart/1Mcolors0.avif";


---

<BaseLayout
  title="QDaria - Leading the Quantum Computing Revolution"
  description="QDaria is researching topological quantum computing based on Fibonacci anyons, combining deep scientific expertise with world-class talent."
>
  <main class="relative bg-dark-bg">
    <!-- Hero Section with electric background -->
    <HeroSideElectric />

    <!-- Blog Marquee -->
    <BlogCloudMarquee />

    <!-- Centered QDaria Logo with floating animation -->
    <div class="flex justify-center py-24 px-4 sm:px-6" role="presentation">
      <img
        src="/icons/qdaria/QDaria_logo_teal.png"
        alt="QDaria - Advancing Topological Quantum Computing through Fibonacci anyon research"
        class="w-full max-w-[280px] sm:max-w-[320px] md:max-w-[380px] lg:max-w-[420px] h-auto animate-float"
      />
    </div>

    <!-- Mission & Vision Section -->
    <section class="relative overflow-hidden bg-dark-bg py-24" aria-labelledby="mission-vision-heading">
      <div class="bg-gradient-radial-dark absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
        <div class="reveal-element" data-animation="fade">
          <h2 id="mission-vision-heading" class="text-gradient-blue mb-16 text-center text-3xl font-bold tracking-tight sm:text-4xl">
            Our Mission & Vision
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2" role="list">
          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105" role="listitem">
            <h3 class="mb-4 text-2xl font-bold text-white" id="mission-heading">Mission</h3>
            <p class="text-base-300" aria-labelledby="mission-heading">
              To revolutionize industries through topological quantum computing, delivering
              innovative solutions that solve complex challenges and shape the future of
              technology. We aim to make quantum computing accessible and impactful across
              cybersecurity, finance, education, and healthcare.
            </p>
          </article>

          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105" role="listitem">
            <h3 class="mb-4 text-2xl font-bold text-white" id="vision-heading">Vision</h3>
            <p class="text-base-300" aria-labelledby="vision-heading">
              To be the global leader in topological quantum computing, driving the quantum
              revolution through cutting-edge research, innovative products, and strategic
              partnerships. We envision a future where quantum computing transforms every
              aspect of society, from secure communications to personalized medicine.
            </p>
          </article>

          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105" role="listitem">
            <h3 class="mb-4 text-2xl font-bold text-white" id="values-heading">Core Values</h3>
            <p class="text-base-300" aria-labelledby="values-heading">
              Integrity, Innovation, Collaboration, Excellence, and Impact. These values
              guide our work and define our culture.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Social Responsibility Section -->
    <section class="relative overflow-hidden bg-dark-bg py-24" aria-labelledby="social-responsibility-heading">
      <div class="bg-gradient-radial-dark absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
        <div class="reveal-element" data-animation="fade">
          <h2 id="social-responsibility-heading" class="text-gradient-blue mb-16 text-center text-3xl font-bold tracking-tight sm:text-4xl">
            Social Responsibility
          </h2>
          <p class="text-base-300 text-center mb-16 max-w-3xl mx-auto">
            In QDaria we take social responsibility seriously and will not only passively donate in a traditional charity fashion but actively be present in the projects we support. A significant amount of our surplus will be earmarked for various projects, with distribution decided annually by our board of directors. We have a dedicated division to execute our duties to stand up tall for those who we truly consider to be the most unfortunate and the weakest in this world.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3" role="list">
          <!-- EcoMoyo Card -->
          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105 group" role="listitem">
            <a href="/ecosystem/social-responsibility/ecomoyo" class="block focus:outline-2 focus:outline-primary-400 focus:outline-offset-4 rounded-lg" aria-labelledby="ecomoyo-heading">
              <h3 id="ecomoyo-heading" class="mb-4 text-2xl font-bold text-white">EcoMoyo</h3>
              <div class="mb-6">
                <Image
                  src={lindsayImage}
                  alt="Lindsay Sanner working with students at the EcoMoyo educational project in Kenya"
                  class="rounded-lg w-full h-auto object-cover aspect-[4/3]"
                />
              </div>
              <div class="text-base-300 select-text">
                We are proud to support one of our true heroes, Lindsay Sanner, and her remarkable EcoMoyo project in Kenya. Starting with just 20 students in 2014, Lindsay's vision has grown to provide free education to 270 children by 2025. Her journey from seeking personal meaning to creating transformative educational opportunities exemplifies the impact one person can have on hundreds of lives.
              </div>
              <div class="mt-4">
                <span class="text-primary-400 group-hover:text-primary-300 transition-colors duration-200" aria-hidden="true">
                  Learn More →
                </span>
              </div>
            </a>
          </article>

          <!-- Art For Change Card -->
          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105 group" role="listitem">
            <a href="/ecosystem/social-responsibility/artforchange" class="block focus:outline-2 focus:outline-primary-400 focus:outline-offset-4 rounded-lg" aria-labelledby="artforchange-heading">
              <h3 id="artforchange-heading" class="mb-4 text-2xl font-bold text-white">Art For Change (Affirmative Art)</h3>
              <div class="mb-6">
                <img
                  src="/images/media/artforchange/artforchange.avif"
                  alt="Contemporary artwork representing the Art For Change initiative connecting socially conscious collectors with artists"
                  class="rounded-lg w-full h-auto object-cover aspect-[4/3]"
                />
              </div>
              <div class="text-base-300 select-text">
                ART FOR CHANGE connects socially conscious art collectors with in-demand contemporary artists and their work. The platform offers museum-quality prints and original works at approachable price points, ensuring artists receive 50% of net proceeds. This commitment supports a thriving cultural ecosystem while affecting positive change through donations to relevant non-profits.
              </div>
              <div class="mt-4">
                <span class="text-primary-400 group-hover:text-primary-300 transition-colors duration-200" aria-hidden="true">
                  Learn More →
                </span>
              </div>
            </a>
          </article>

          <!-- SciArt Card -->
          <article class="feature-card rounded-xl p-8 transition-transform duration-300 hover:scale-105 group" role="listitem">
            <a href="/ecosystem/social-responsibility/sciart" class="block focus:outline-2 focus:outline-primary-400 focus:outline-offset-4 rounded-lg" aria-labelledby="sciart-heading">
              <h3 id="sciart-heading" class="mb-4 text-2xl font-bold text-white">SciArt</h3>
              <div class="mb-6">
                <Image
                  src={sciartImage}
                  alt="Scientific visualization artwork from the SciArt project showcasing the intersection of science and artistic expression"
                  class="rounded-lg w-full h-auto object-cover aspect-[4/3]"
                />
              </div>
              <div class="text-base-300 select-text">
                Our in-house SciArt project combines artistic expression with social impact. Through this initiative, we create and curate art that not only celebrates the beauty of science but also supports vital causes. A significant portion of proceeds goes directly to our supported projects, creating a bridge between artistic appreciation and meaningful social change.
              </div>
              <div class="mt-4">
                <span class="text-primary-400 group-hover:text-primary-300 transition-colors duration-200" aria-hidden="true">
                  Learn More →
                </span>
              </div>
            </a>
          </article>
        </div>
      </div>
    </section>

    <style>
      @keyframes float {
        0%, 100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-20px);
        }
      }
      .animate-float {
        animation: float 4s ease-in-out infinite;
      }
    </style>

    <!-- Logos / Collaborators carousel -->
    <div class="relative z-10 py-12">
      <LogoCloudMarquee />
    </div>

    <!-- Quick Feature Cards -->
    <FeatureCardsSmall />

    <!-- Zipminator Waiting List Section -->
    <section class="relative overflow-hidden bg-dark-bg py-24" aria-labelledby="zipminator-heading">
      <div class="bg-gradient-radial-dark absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
        <div class="reveal-element" data-animation="fade">
          <div class="mx-auto max-w-3xl text-center">
            <h2 id="zipminator-heading" class="text-gradient-blue mb-8 text-3xl font-bold tracking-tight sm:text-4xl">
              Secure Your Future with Zipminator
            </h2>
            <p class="text-lg leading-8 text-base-300 mb-10">
              The quantum era brings new threats to digital security. Zipminator is our answer—a quantum-safe cybersecurity platform integrating NIST's post-quantum cryptography standards. Don't wait for the threat to arrive.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
              <a
                href="/technology/products/zipminator"
                class="inline-flex items-center justify-center rounded-lg bg-primary-500 px-8 py-4 text-lg font-medium text-white shadow-lg transition-all hover:bg-primary-600 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-dark-bg"
              >
                Join the Waiting List
              </a>
              <a
                href="/blog/zipminator-pqc-super-app"
                class="text-primary-400 hover:text-primary-300 font-medium transition-colors"
              >
                Read the Full Story →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- History Teaser -->
    <section class="relative overflow-hidden bg-dark-bg py-16 border-t border-primary-500/10">
      <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Our Journey</h2>
        <p class="text-base-300 mb-8 max-w-2xl mx-auto">
          From our origins in DariaSH to the roadmap for the world's first fault-tolerant topological quantum computer.
        </p>
        <a
          href="/company/history"
          class="inline-flex items-center justify-center rounded-lg border border-primary-500/30 bg-dark-bg/50 px-6 py-2 text-base font-medium text-primary-400 transition-all hover:bg-primary-500/10 hover:border-primary-500"
        >
          View Full Timeline →
        </a>
      </div>
    </section>

    <!-- CTA Lightning -->
    <CtaLightning />
  </main>
</BaseLayout>

<style>
  .text-gradient-blue {
    @apply bg-gradient-to-r from-[#04a3ff] via-[#00ffd3] to-[#65ff00] bg-clip-text text-transparent;
    filter: brightness(1.8) saturate(1.4);
    text-shadow: 0 0 30px rgba(4, 163, 255, 0.4);
    animation: pulse-gradient 4s ease-in-out infinite;
  }

  @keyframes pulse-gradient {
    0%,
    100% {
      filter: brightness(1.8) saturate(1.4);
      text-shadow: 0 0 30px rgba(4, 163, 255, 0.4);
    }
    50% {
      filter: brightness(2) saturate(1.6);
      text-shadow: 0 0 40px rgba(4, 163, 255, 0.5);
    }
  }

  .feature-card {
    @apply relative rounded-2xl border border-primary-500/30 bg-dark-bg/80 backdrop-blur-sm transition-all duration-500 overflow-visible;
    box-shadow: 0 0 25px rgba(4, 163, 255, 0.4);

    &:hover {
      box-shadow: 0 0 50px rgba(4, 163, 255, 0.6);
      transform: translateY(-4px) scale(1.02);
      @apply border-primary-500/50 bg-dark-bg/90;
      animation: pulse-card 2s ease-in-out infinite;
    }

    @keyframes pulse-card {
      0%,
      100% {
        box-shadow: 0 0 50px rgba(4, 163, 255, 0.6);
      }
      50% {
        box-shadow: 0 0 70px rgba(4, 163, 255, 0.8);
      }
    }

    &::before {
      content: "";
      @apply absolute inset-0 rounded-2xl;
      background: radial-gradient(
        800px circle at var(--mouse-x, 0) var(--mouse-y, 0),
        rgba(4, 163, 255, 0.15),
        transparent 40%
      );
      opacity: 0;
      transition: opacity 0.5s;
    }

    &:hover::before {
      opacity: 1;
    }
  }

  .timeline-line {
    @apply absolute left-1/2 top-0 h-full w-0.5 bg-primary-500/30;
    box-shadow: 0 0 20px rgba(4, 163, 255, 0.4);
    animation: glow 2s ease-in-out infinite;
  }

  .timeline-dot {
    @apply absolute left-1/2 h-4 w-4 -translate-x-1/2 rounded-full border-4 border-dark-bg bg-primary-500;
    box-shadow: 0 0 15px rgba(4, 163, 255, 0.5);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes glow {
    0%,
    100% {
      box-shadow: 0 0 20px rgba(4, 163, 255, 0.4);
    }
    50% {
      box-shadow: 0 0 30px rgba(4, 163, 255, 0.6);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      transform: translate(-50%, 0) scale(1);
      box-shadow: 0 0 15px rgba(4, 163, 255, 0.5);
    }
    50% {
      transform: translate(-50%, 0) scale(1.1);
      box-shadow: 0 0 25px rgba(4, 163, 255, 0.7);
    }
  }

  .reveal-element {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-element.gsap-ready {
    opacity: 0;
    transform: translateY(20px);
  }

  /* Global focus indicators for accessibility */
  *:focus-visible {
    outline: 2px solid #04a3ff;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Enhanced focus for interactive elements */
  a:focus-visible,
  button:focus-visible {
    outline: 3px solid #04a3ff;
    outline-offset: 3px;
    box-shadow: 0 0 0 5px rgba(4, 163, 255, 0.2);
  }

  /* Screen reader only content */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }

    .animate-float {
      animation: none;
    }
  }

  /* Hide timeline line on mobile for cleaner look */
  @media (max-width: 768px) {
    .timeline-line {
      display: none;
    }
  }
</style>

<script>
  // SSR Guard: Only execute on client-side
  if (typeof window !== 'undefined') {
    import('gsap').then(({ gsap }) => {
      import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);

        // Check if user prefers reduced motion
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Optimized mouse position update with requestAnimationFrame
        let rafId: number | null = null;
        let mouseX = 0;
        let mouseY = 0;
        let currentTarget: HTMLElement | null = null;

        function updateMousePosition(e: Event) {
          const target = e.currentTarget as HTMLElement;
          const mouseEvent = e as MouseEvent;

          mouseX = mouseEvent.clientX;
          mouseY = mouseEvent.clientY;
          currentTarget = target;

          // Cancel previous animation frame if it exists
          if (rafId !== null) {
            cancelAnimationFrame(rafId);
          }

          // Use requestAnimationFrame to throttle updates
          rafId = requestAnimationFrame(() => {
            if (!currentTarget) return;

            const rect = currentTarget.getBoundingClientRect();
            const x = mouseX - rect.left;
            const y = mouseY - rect.top;

            currentTarget.style.setProperty("--mouse-x", `${x}px`);
            currentTarget.style.setProperty("--mouse-y", `${y}px`);

            rafId = null;
          });
        }

        function initCards() {
          const cards = document.querySelectorAll(".feature-card");

          // Only add mouse tracking if motion is allowed
          if (!prefersReducedMotion) {
            cards.forEach((el) => {
              el.removeEventListener("mousemove", updateMousePosition as EventListener);
              el.addEventListener("mousemove", updateMousePosition as EventListener);

              // Clean up on mouse leave
              el.addEventListener("mouseleave", () => {
                if (rafId !== null) {
                  cancelAnimationFrame(rafId);
                  rafId = null;
                }
                currentTarget = null;
              });
            });
          }

          // Reset all timeline descriptions to collapsed state on page load
          document.querySelectorAll('[id^="timeline-description-"]').forEach((description) => {
            if (!description.classList.contains('line-clamp-3')) {
              description.classList.add('line-clamp-3');
            }
          });

          // Clean up and re-initialize read-more buttons
          document.querySelectorAll(".read-more-btn").forEach((btn) => {
      // Reset button state to default
      btn.setAttribute('aria-expanded', 'false');
      const visibleText = btn.querySelector('[aria-hidden="true"]');
      if (visibleText) {
        visibleText.textContent = 'Read More ↓';
      }

      // Remove old event listeners by cloning the node
      const newBtn = btn.cloneNode(true) as HTMLElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      // Keyboard accessibility - activate on Enter and Space
      newBtn.addEventListener("keydown", (e: Event) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === "Enter" || keyEvent.key === " ") {
          e.preventDefault();
          newBtn.click();
        }
      });

      // Add fresh event listener to prevent duplicate handlers
      newBtn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        const parent = newBtn.parentElement;
        const description = parent ? parent.previousElementSibling : null;

        if (description) {
          const isCurrentlyExpanded = newBtn.getAttribute('aria-expanded') === 'true';
          const newExpandedState = !isCurrentlyExpanded;

          // Toggle content visibility
          description.classList.toggle('line-clamp-3');

          // Update ARIA state correctly
          newBtn.setAttribute('aria-expanded', String(newExpandedState));

          // Update visible text
          const newVisibleText = newBtn.querySelector('[aria-hidden="true"]');
          if (newVisibleText) {
            newVisibleText.textContent = newExpandedState ? 'Read Less ↑' : 'Read More ↓';
          }

          // Store state in sessionStorage for persistence during session
          const descriptionId = description.id;
          if (descriptionId) {
            sessionStorage.setItem(`timeline-${descriptionId}`, newExpandedState ? 'expanded' : 'collapsed');
          }

          // Announce change to screen readers
          const announcement = document.createElement('div');
          announcement.className = 'sr-only';
          announcement.setAttribute('role', 'status');
          announcement.setAttribute('aria-live', 'polite');
          announcement.textContent = newExpandedState ? 'Timeline entry expanded' : 'Timeline entry collapsed';
          document.body.appendChild(announcement);
          setTimeout(() => announcement.remove(), 1000);
        }
      });
    });

    // Restore state from sessionStorage if user previously expanded items
    document.querySelectorAll('[id^="timeline-description-"]').forEach((description) => {
      const descriptionId = description.id;
      const savedState = sessionStorage.getItem(`timeline-${descriptionId}`);

      if (savedState === 'expanded') {
        description.classList.remove('line-clamp-3');
        const btn = description.parentElement?.querySelector('.read-more-btn');
        if (btn) {
          btn.setAttribute('aria-expanded', 'true');
          const visibleText = btn.querySelector('[aria-hidden="true"]');
          if (visibleText) {
            visibleText.textContent = 'Read Less ↑';
          }
        }
      }
    });
  }

  function initAnimations() {
    const elements = document.querySelectorAll(".reveal-element");

    // Skip GSAP animations if user prefers reduced motion
    if (prefersReducedMotion) {
      // Elements are already visible, just ensure no transforms
      elements.forEach((element) => {
        (element as HTMLElement).style.opacity = '1';
        (element as HTMLElement).style.transform = 'none';
      });
      return;
    }

    // Mark elements as ready for GSAP animation
    elements.forEach(el => el.classList.add('gsap-ready'));

    // Batch GSAP animations with optimized settings
    const batchSize = 5; // Process elements in batches
    let currentBatch = 0;

    function processBatch() {
      const start = currentBatch * batchSize;
      const end = Math.min(start + batchSize, elements.length);

      for (let i = start; i < end; i++) {
        const element = elements[i];
        const delay = element.getAttribute("data-delay") || "0";

        gsap.to(element, {
          opacity: 1,
          y: 0,
          duration: 1.2,
          delay: parseFloat(delay),
          ease: "power3.out",
          scrollTrigger: {
            trigger: element,
            start: "top 85%",
            toggleActions: "play none none reverse",
            // Optimize ScrollTrigger performance
            fastScrollEnd: true,
            preventOverlaps: true,
          },
        });
      }

      currentBatch++;

      // Process next batch if there are more elements
      if (end < elements.length) {
        requestAnimationFrame(processBatch);
      }
    }

    // Start processing batches
    processBatch();
  }

  // Clean up function
  function cleanup() {
    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
    currentTarget = null;

    // Kill all GSAP animations and ScrollTriggers
    ScrollTrigger.getAll().forEach(trigger => trigger.kill());
    gsap.killTweensOf("*");
  }

  // Initialize after DOM is fully loaded
  if (document.readyState === 'complete') {
    initCards();
    initAnimations();
  } else {
    window.addEventListener('load', () => {
      initCards();
      initAnimations();
    });
  }

  // Re-initialize after Astro page transitions
  document.addEventListener("astro:page-load", () => {
    cleanup();
    setTimeout(() => {
      initCards();
      initAnimations();
    }, 100);
  });

  document.addEventListener("astro:after-swap", () => {
    cleanup();
    setTimeout(() => {
      initCards();
      initAnimations();
    }, 100);
  });

        // Clean up on page unload
        window.addEventListener("beforeunload", cleanup);
      }).catch(err => console.warn('ScrollTrigger import failed:', err));
    }).catch(err => console.warn('GSAP import failed:', err));
  }
</script>
