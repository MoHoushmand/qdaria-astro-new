---
import BaseHead from '../../layouts/BaseHead.astro';

const error = Astro.url.searchParams.get('error');
const hasGitHub = !!process.env.AUTH_GITHUB_ID;
const hasGoogle = !!process.env.AUTH_GOOGLE_ID;
const hasLinkedIn = !!process.env.AUTH_LINKEDIN_ID;
const hasAnyOAuth = hasGitHub || hasGoogle || hasLinkedIn;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title="Admin Login - QDaria" description="Sign in to QDaria Admin Portal" />
  </head>
  <body class="flex min-h-screen items-center justify-center bg-[#0a0e1a] font-sans antialiased dark">
    <div class="mx-auto w-full max-w-md px-4">
      <!-- Logo -->
      <div class="mb-8 flex flex-col items-center">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-cyan-500/10">
          <span class="text-xl font-bold text-cyan-400">QD</span>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-white">QDaria Admin</h1>
        <p class="mt-1 text-sm text-gray-500">Internal team portal</p>
      </div>

      <!-- Error messages -->
      {error === 'unauthorized' && (
        <div class="mb-4 rounded-lg border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-400">
          Access denied. You must be a team member to access the admin portal.
        </div>
      )}
      {error && error !== 'unauthorized' && (
        <div class="mb-4 rounded-lg border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-400">
          {error === 'MissingCSRF' && 'Authentication error. Please try again.'}
          {error === 'Configuration' && 'Authentication service is not configured properly. Contact your administrator.'}
          {error === 'AccessDenied' && 'Access was denied by the provider.'}
          {error === 'OAuthCallback' && 'OAuth provider rejected the redirect. The callback URL is not whitelisted in the provider’s OAuth app settings.'}
          {error === 'OAuthCallbackError' && 'OAuth provider rejected the redirect. The callback URL is not whitelisted in the provider’s OAuth app settings.'}
          {error === 'OAuthSignin' && 'Could not start sign-in with this provider.'}
          {error === 'Callback' && 'Sign-in failed at the callback step. The provider client ID/secret may be wrong.'}
          {error === 'CallbackRouteError' && 'Sign-in failed at the callback step. The provider client ID/secret may be wrong.'}
          {!['MissingCSRF','Configuration','AccessDenied','OAuthCallback','OAuthCallbackError','OAuthSignin','Callback','CallbackRouteError','unauthorized'].includes(error) && `Error: ${error}`}
        </div>
      )}

      <!-- Sign-in card -->
      <div class="rounded-xl border border-gray-800 bg-[#111827] p-8">
        <p class="mb-6 text-center text-sm text-gray-400">
          Sign in with your company-linked account
        </p>

        {hasAnyOAuth && (
          <div class="space-y-3" id="auth-buttons">
            {hasGitHub && (
              <button
                type="button"
                data-oauth-provider="github"
                class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-700 bg-[#0a0e1a] px-4 py-3 text-sm font-medium text-gray-300 transition-colors hover:border-gray-600 hover:text-white"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Continue with GitHub
              </button>
            )}

            {hasGoogle && (
              <button
                type="button"
                data-oauth-provider="google"
                class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-700 bg-[#0a0e1a] px-4 py-3 text-sm font-medium text-gray-300 transition-colors hover:border-gray-600 hover:text-white"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Continue with Google
              </button>
            )}

            {hasLinkedIn && (
              <button
                type="button"
                data-oauth-provider="linkedin"
                class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-700 bg-[#0a0e1a] px-4 py-3 text-sm font-medium text-gray-300 transition-colors hover:border-gray-600 hover:text-white"
              >
                <svg class="h-5 w-5" fill="#0A66C2" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Continue with LinkedIn
              </button>
            )}
          </div>

          <div class="my-6 flex items-center gap-3">
            <div class="h-px flex-1 bg-gray-700"></div>
            <span class="text-xs text-gray-500">or use staff credentials</span>
            <div class="h-px flex-1 bg-gray-700"></div>
          </div>
        )}

        {!hasAnyOAuth && (
          <p class="mb-4 text-center text-xs text-gray-500">
            Use your assigned staff credentials to sign in
          </p>
        )}

        <!-- Credentials form -->
        <form id="credentials-form" class="space-y-3">
          <input
            id="cred-username"
            type="text"
            placeholder="Username"
            required
            class="w-full rounded-lg border border-gray-700 bg-[#0a0e1a] px-4 py-3 text-sm text-gray-200 placeholder-gray-500 outline-none transition-colors focus:border-cyan-500/50"
          />
          <input
            id="cred-password"
            type="password"
            placeholder="Password"
            required
            class="w-full rounded-lg border border-gray-700 bg-[#0a0e1a] px-4 py-3 text-sm text-gray-200 placeholder-gray-500 outline-none transition-colors focus:border-cyan-500/50"
          />
          <button
            type="submit"
            class="flex w-full items-center justify-center gap-2 rounded-lg bg-cyan-500 px-4 py-3 text-sm font-medium text-black transition-colors hover:bg-cyan-400"
          >
            Sign In
          </button>
          <p id="cred-error" class="hidden text-center text-xs text-red-400"></p>
        </form>

        <p class="mt-6 text-center text-xs text-gray-600">
          Only QDaria team members can access this portal.
        </p>
      </div>

      <!-- Back to main site -->
      <div class="mt-6 text-center">
        <a href="/" class="text-sm text-gray-500 transition-colors hover:text-gray-400">
          &larr; Back to qdaria.com
        </a>
      </div>
    </div>

    <script>
      import { signIn } from "auth-astro/client";

      const callbackUrl = () =>
        new URLSearchParams(window.location.search).get('callbackUrl') || '/admin/dashboard';

      // OAuth buttons — auth-astro v4 requires POST w/ CSRF; signIn() does this internally.
      document.querySelectorAll<HTMLButtonElement>('[data-oauth-provider]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const provider = btn.dataset.oauthProvider as 'github' | 'google' | 'linkedin';
          signIn(provider, { callbackUrl: callbackUrl() });
        });
      });

      document.getElementById('credentials-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const username = (document.getElementById('cred-username') as HTMLInputElement)?.value.trim();
        const password = (document.getElementById('cred-password') as HTMLInputElement)?.value;
        const errorEl = document.getElementById('cred-error');

        if (!username || !password) return;

        // Accept either "daniel.mo.houshmand" or "daniel.mo.houshmand@qdaria.com";
        // strip the domain so the STAFF_CREDENTIALS_JSON username key matches.
        const shortUsername = username.includes('@')
          ? username.split('@')[0].toLowerCase()
          : username.toLowerCase();

        try {
          await signIn('credentials', {
            username: shortUsername,
            password,
            redirect: true,
            callbackUrl: callbackUrl(),
          });
        } catch (err) {
          if (errorEl) {
            errorEl.textContent = 'Invalid credentials. Try again.';
            errorEl.classList.remove('hidden');
          }
        }
      });
    </script>
  </body>
</html>
