---
import { type CollectionEntry, getEntries } from "astro:content";
import { Image } from "astro:assets";
import { getImage } from "astro:assets";
import { Icon } from "astro-icon/components";

// KaTeX CSS for math equations
import "katex/dist/katex.min.css";

// main layout
import BaseLayout from "./BaseLayout.astro";

// components
import Category from "../components/Category/Category.astro";
import Button from "../components/Button/Button.astro";
import TableOfContents from "../components/TableOfContents/TableOfContents.astro";

// utils
import { formatDate, humanize, slugify } from "../js/textUtils";
import { getLocaleFromUrl } from "../js/localeUtils";
import { useTranslations } from "../js/translationUtils";

interface Author {
  name: string;
  role?: string;
  bio?: string;
  avatar: ImageMetadata;
  email?: string;
  linkedin?: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const {
  title,
  description,
  authors,
  categories,
  pubDate,
  updatedDate,
  heroImage,
} = post.data;

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations({ url: Astro.url, locals: { locale: currLocale } });
interface AuthorEntry {
  collection: "authors";
  id: string;
}

const authorEntries = authors 
  ? await getEntries(authors.map((author: string): AuthorEntry => ({ 
      collection: "authors", 
      id: author 
    }))) as CollectionEntry<"authors">[]
  : [];
---

<BaseLayout
  type="blog"
  title={title}
  description={description}
  image={heroImage}
  authorsData={authorEntries}
  postFrontmatter={post.data}
>
  <article class="site-container mt-20 md:mt-28">
    <!-- Blog post info -->
    <div class="flex w-full flex-col items-center">
      <div class="mx-auto flex w-full max-w-[800px]">
        <div class="mx-auto text-center">
          <nav class="flex w-full justify-center gap-3 md:text-lg">
            {categories.map((category: string) => (
              <Category category={category} />
            ))}
          </nav>

          <h1 class="h2 mt-4 text-gradient-blue">{title}</h1>

          <div class="mt-2 flex w-full flex-wrap justify-center gap-3">
            {authorEntries.map((authorData) => (
              <div class="mb-auto flex">
                <figure>
                  <img
                    src={authorData.data.avatar}
                    alt={`${authorData.data.name} avatar`}
                    width="100"
                    height="100"
                    class="h-7 w-7 rounded-full border border-base-300 object-cover dark:border-base-700"
                  />
                </figure>
                <div class="my-auto ml-2">{authorData.data.name}</div>
              </div>
            ))}
            <div class="my-auto">&bull;</div>
            <time class="my-auto h-full" datetime={pubDate.toISOString()}>
              {formatDate(pubDate, currLocale)}
            </time>
          </div>
        </div>
      </div>

      <!-- blog post main image -->
      {heroImage && (
        <div class="hero-image-wrapper">
          <img
            src={heroImage}
            alt={`Cover for ${title}`}
            width="1408"
            height="800"
            class="max-h-[70vh] w-full object-cover"
            loading="eager"
          />
        </div>
      )}
    </div>

    <!-- article content -->
    <div class="mt-10 w-full px-4 sm:px-0">
      <div
        class="mx-auto flex max-w-3xl flex-col gap-6 lg:grid lg:max-w-none lg:grid-cols-12"
      >
        <!-- left sidebar -->
        <aside class="hidden lg:col-span-2 lg:block">
          <div class="sticky top-20">
            <div class="h-[calc(100vh-6rem)] overflow-y-auto">
              <!-- You can put a CTA or whatever else you want here -->
              <!-- <div class="h-full w-full bg-blue-500"></div> -->
            </div>
          </div>
        </aside>

        <!-- Content -->
        <div class="text-base-content text-base lg:col-span-7">
          {
            updatedDate && (
              <div class="mb-6 italic">
                <time datetime={updatedDate.toISOString()}>
                  Updated: {formatDate(updatedDate, currLocale)}
                </time>
              </div>
            )
          }
          <section id="blog-post-content" class="blog-prose prose prose-invert mx-auto md:text-lg">
            <slot />
          </section>

          <!-- button to go back to all posts -->
          <div class="mt-10 flex justify-center">
            <Button variant="outline" href="/blog/" arrow="left">
              Back to all posts
            </Button>
          </div>
        </div>

        <!-- Table of Contents sidebar -->
        <aside class="hidden lg:col-span-3 lg:block">
          <div class="sticky top-20">
            <div class="h-[calc(100vh-6rem)] overflow-y-auto">
              <TableOfContents headings={headings} levels={3} />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>



<!--
  KaTeX rendering is handled at build-time via remark-math + rehype-katex in astro.config.mjs
  DO NOT add client-side auto-render scripts here - it causes DOUBLE RENDERING
  which creates "double button" visual artifacts on equations.

  The build-time pipeline is:
  1. remark-math identifies $$...$$ and $...$ delimiters
  2. rehype-katex converts them to rendered .katex HTML
  3. KaTeX CSS (imported in BaseLayout) styles them

  If you see math not rendering, check astro.config.mjs, not this file.
-->

<style>
  .text-gradient-blue {
    @apply bg-gradient-to-r from-[#04a3ff] via-[#00ffd3] to-[#65ff00] bg-clip-text text-transparent;
    filter: brightness(1.8) saturate(1.4);
    text-shadow: 0 0 30px rgba(4, 163, 255, 0.4);
    animation: pulse-gradient 4s ease-in-out infinite;
  }

  @keyframes pulse-gradient {
    0%,
    100% {
      filter: brightness(1.8) saturate(1.4);
      text-shadow: 0 0 30px rgba(4, 163, 255, 0.4);
    }
    50% {
      filter: brightness(2) saturate(1.6);
      text-shadow: 0 0 40px rgba(4, 163, 255, 0.5);
    }
  }

  /* Style for inline math to look like subtle buttons */
  :global(.blog-prose .katex) {
    background: rgba(4, 163, 255, 0.1) !important;
    border: 1px solid rgba(4, 163, 255, 0.2) !important;
    border-radius: 4px;
    padding: 2px 6px;
    margin: 0 2px;
    box-shadow: 0 0 10px rgba(4, 163, 255, 0.1);
    transition: all 0.3s ease;
    font-size: 0.95em;
  }

  :global(.blog-prose .katex:hover) {
    background: rgba(4, 163, 255, 0.2) !important;
    border-color: rgba(4, 163, 255, 0.4) !important;
    box-shadow: 0 0 15px rgba(4, 163, 255, 0.3);
  }

  /* Reset style for display math to keep it clean */
  :global(.blog-prose .katex-display .katex) {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Style for all images in the blog content */
  :global(.blog-prose img) {
    border-radius: 0.75rem;
    border: 1px solid rgba(4, 163, 255, 0.3);
    background-color: rgba(13, 17, 23, 0.8);
    box-shadow: 0 0 25px rgba(4, 163, 255, 0.4);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Hero Image Wrapper - Interactive Island Style */
  .hero-image-wrapper {
    position: relative;
    margin: 2rem 0;
    padding: 0.75rem; /* Create space for the image inside the island */
    background: rgba(0, 2, 18, 0.6);
    border: 1px solid rgba(4, 163, 255, 0.25);
    border-radius: 12px;
    box-shadow:
      0 4px 20px rgba(4, 163, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    /* overflow: hidden; Removed to ensure glowing border is visible */
  }

  .hero-image-wrapper:hover {
    border-color: rgba(4, 163, 255, 0.6);
    box-shadow:
      0 0 40px rgba(4, 163, 255, 0.25),
      0 0 80px rgba(4, 163, 255, 0.1),
      0 8px 40px rgba(4, 163, 255, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  /* Glowing border effect on hover */
  .hero-image-wrapper::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    padding: 2px;
    background: linear-gradient(
      135deg,
      rgba(4, 163, 255, 0.5),
      rgba(0, 206, 209, 0.3),
      rgba(4, 163, 255, 0.5)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 10;
  }

  .hero-image-wrapper:hover::before {
    opacity: 1;
  }

  .hero-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px; /* Slightly less than wrapper to fit inside */
    transition: transform 0.3s ease;
  }

  .hero-image-wrapper:hover img {
    transform: scale(1.005);
  }
</style>
