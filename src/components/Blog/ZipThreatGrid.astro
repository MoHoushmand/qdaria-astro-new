---
/**
 * ZipThreatGrid - Threat cards + interactive severity radar chart
 * Displays the quantum and classical threats motivating Zipminator
 */
import ZipThreatRadar from './charts/ZipThreatRadar';

interface Props {
  title?: string;
}

const { title = "The Threat Landscape" } = Astro.props;

const threats = [
  {
    name: 'Salt Typhoon',
    detail: '200+ companies, 80 countries compromised (2024-2025)',
    source: 'FBI/CISA Joint Advisory',
    severity: 'critical',
    icon: '🌍',
  },
  {
    name: 'SS7 Exploitation',
    detail: 'Ongoing attacks, new bypass discovered late 2024',
    source: 'DHS confirmed 4 nations exploiting',
    severity: 'critical',
    icon: '📡',
  },
  {
    name: 'Harvest Now, Decrypt Later',
    detail: 'Active data exfiltration for future quantum decryption',
    source: 'DHS, UK NCSC, ENISA, Federal Reserve',
    severity: 'high',
    icon: '🗄️',
  },
  {
    name: 'Quantum Breakthrough 2025',
    detail: 'Qubit requirements reduced 95% (20M to less than 1M physical qubits)',
    source: 'Multiple research groups',
    severity: 'high',
    icon: '⚡',
  },
  {
    name: 'CNSA 2.0 Deadline',
    detail: 'All new NSS equipment must be CNSA 2.0-compliant by 2027',
    source: 'NSA',
    severity: 'urgent',
    icon: '🛡️',
  },
];

const severityColors: Record<string, string> = {
  critical: '#ff3b3b',
  high: '#ffa500',
  urgent: '#ff6b6b',
};
---

<section class="threat-section">
  <div class="threat-header">
    <h3 class="threat-title">{title}</h3>
    <span class="threat-count">{threats.length} active threats</span>
  </div>
  <div class="threat-grid">
    {threats.map((t) => (
      <div class="threat-card">
        <div class="threat-top">
          <span class="threat-icon">{t.icon}</span>
          <span class="severity-badge" style={`background: ${severityColors[t.severity]}22; color: ${severityColors[t.severity]}; border-color: ${severityColors[t.severity]}44;`}>
            {t.severity.toUpperCase()}
          </span>
        </div>
        <h4 class="threat-name">{t.name}</h4>
        <p class="threat-detail">{t.detail}</p>
        <p class="threat-source">Source: {t.source}</p>
      </div>
    ))}
  </div>

  <!-- Interactive Threat Radar (React Island) -->
  <ZipThreatRadar client:visible />
</section>

<style>
  .threat-section {
    position: relative;
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: rgba(0, 2, 18, 0.4);
    border: 1px solid rgba(4, 163, 255, 0.25);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(4, 163, 255, 0.1);
    transition: all 0.3s ease;
  }

  .threat-section:hover {
    border-color: rgba(4, 163, 255, 0.4);
  }

  .threat-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(4, 163, 255, 0.2);
  }

  .threat-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ff3b3b 0%, #ffa500 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    flex: 1;
  }

  .threat-count {
    font-size: 0.8rem;
    color: #ff3b3b;
    padding: 4px 10px;
    background: rgba(255, 59, 59, 0.1);
    border-radius: 12px;
    border: 1px solid rgba(255, 59, 59, 0.2);
  }

  .threat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .threat-card {
    position: relative;
    padding: 1.25rem;
    background: rgba(0, 2, 18, 0.6);
    border: 1px solid rgba(255, 59, 59, 0.15);
    border-radius: 10px;
    transition: all 0.3s ease;
  }

  .threat-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    padding: 2px;
    background: linear-gradient(135deg, rgba(255, 59, 59, 0.4), rgba(255, 165, 0, 0.3), rgba(255, 59, 59, 0.4));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 10;
  }

  .threat-card:hover {
    border-color: rgba(255, 59, 59, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(255, 59, 59, 0.15);
  }

  .threat-card:hover::before {
    opacity: 1;
  }

  .threat-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .threat-icon {
    font-size: 1.5rem;
  }

  .severity-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid;
    letter-spacing: 0.05em;
  }

  .threat-name {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
  }

  .threat-detail {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
  }

  .threat-source {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .threat-card { transition: none; }
    .threat-card:hover { transform: none; }
  }
</style>
