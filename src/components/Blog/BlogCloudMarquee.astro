---
import { getCollection } from 'astro:content';
import { removeLocaleFromSlug } from '@js/localeUtils';

// Only show the three flagship posts in the marquee
const allowedSlugs = [
  'en/zipminator-pqc-super-app',
  'en/qrc-sample-efficiency-crisis',
  'en/tqrc-unitarity-echo-state',
];

const posts = await getCollection('blog', ({ data }) => data.draft !== true);
const featuredPosts = posts
  .filter(post => allowedSlugs.includes(post.slug))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

// Duplicate posts to ensure smooth infinite scroll
const marqueePosts = [...featuredPosts, ...featuredPosts, ...featuredPosts];
---

<section class="relative z-20 overflow-hidden bg-dark-bg py-12 border-y border-primary-500/10">
  <div class="marquee-container">
    <div class="marquee">
      <div class="marquee-content flex items-stretch gap-8">
        {
          marqueePosts.map((post) => (
            <a 
              href={`/company/blog/${removeLocaleFromSlug(post.slug)}`}
              class="flex flex-col gap-4 group min-w-[320px] max-w-[320px] p-4 rounded-2xl border border-primary-500/20 bg-dark-bg/50 hover:bg-primary-500/10 hover:border-primary-500/50 transition-all duration-300"
            >
              {post.data.heroImage && (
                <div class="w-full h-48 rounded-xl overflow-hidden border border-primary-500/30 shadow-[0_0_15px_rgba(4,163,255,0.3)] group-hover:shadow-[0_0_25px_rgba(4,163,255,0.5)] transition-all duration-300">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    width="600"
                    height="400"
                  />
                </div>
              )}
              <div class="flex flex-col gap-2 flex-grow">
                <span class="text-primary-400 font-mono text-xs">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                <h3 class="text-lg font-bold leading-tight text-gradient-blue line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="text-base-300 text-sm line-clamp-3 leading-snug">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))
        }
      </div>
      <div class="marquee-content flex items-stretch gap-8" aria-hidden="true">
        {
          marqueePosts.map((post) => (
            <a
              href={`/company/blog/${removeLocaleFromSlug(post.slug)}`}
              class="flex flex-col gap-4 group min-w-[320px] max-w-[320px] p-4 rounded-2xl border border-primary-500/20 bg-dark-bg/50 hover:bg-primary-500/10 hover:border-primary-500/50 transition-all duration-300"
            >
              {post.data.heroImage && (
                <div class="w-full h-48 rounded-xl overflow-hidden border border-primary-500/30 shadow-[0_0_15px_rgba(4,163,255,0.3)] group-hover:shadow-[0_0_25px_rgba(4,163,255,0.5)] transition-all duration-300">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    width="600"
                    height="400"
                  />
                </div>
              )}
              <div class="flex flex-col gap-2 flex-grow">
                <span class="text-primary-400 font-mono text-xs">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                <h3 class="text-lg font-bold leading-tight text-gradient-blue line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="text-base-300 text-sm line-clamp-3 leading-snug">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient-blue {
    @apply bg-gradient-to-r from-[#04a3ff] via-[#00ffd3] to-[#65ff00] bg-clip-text text-transparent;
    filter: brightness(1.8) saturate(1.4);
    text-shadow: 0 0 20px rgba(4, 163, 255, 0.3);
  }

  .marquee-container {
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    width: 100%;
    overflow: hidden;
  }

  .marquee {
    display: flex;
    overflow: hidden;
    width: 100%;
  }

  .marquee-content {
    flex-shrink: 0;
    display: flex;
    justify-content: space-around;
    min-width: 100%;
    gap: 2rem;
    animation: scroll 120s linear infinite;
    padding-left: 2rem; 
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-100%);
    }
  }

  .marquee:hover .marquee-content {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
      overflow-x: auto;
    }
  }
</style>

<script>
  function initMarquee() {
    const marquee = document.querySelector(".marquee");
    if (!marquee) return;
    
    // Logic to clone content if needed for smoother loop could go here
    // but we handled it with static duplication in the template for simplicity
  }

  // Initialize on page load
  initMarquee();
  document.addEventListener("astro:after-swap", initMarquee);
</script>
