---
/**
 * ZipPricing - 4-tier pricing cards with highlighted Pro tier
 * Displays pricing tiers with glowing highlight on the recommended tier
 */
interface Props {
  title?: string;
}

const { title = "Pricing Tiers" } = Astro.props;

const tiers = [
  {
    name: 'Free',
    price: '$0',
    target: 'Individual users',
    features: ['Basic PQC messenger', 'Anonymization levels 1-3', 'Community support', '1 GB data limit'],
    highlighted: false,
    cta: 'Star us on GitHub',
  },
  {
    name: 'Developer',
    price: '$9/mo',
    target: 'Indie devs, small teams',
    features: ['PQC API access', 'Anonymization levels 1-5', '10 GB data limit', 'Email support', 'SDK integration'],
    highlighted: false,
    cta: 'Start Free Trial',
  },
  {
    name: 'Pro',
    price: '$29/mo',
    target: 'SMBs, security teams',
    features: ['Full super-app access', 'Anonymization levels 1-7', '100 GB data limit', 'Team management & SSO', 'Priority support'],
    highlighted: true,
    cta: 'Start Free Trial',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    target: 'Government, military, banking',
    features: ['All levels + QRNG', 'On-premise deployment', 'HSM support & SLA 99.99%', 'Workshops & certifications', 'Dedicated CSM'],
    highlighted: false,
    cta: 'Contact Sales',
  },
];
---

<section class="pricing-section">
  <div class="pricing-header">
    <h3 class="pricing-title">{title}</h3>
  </div>
  <div class="pricing-grid">
    {tiers.map((t) => (
      <div class={`pricing-card ${t.highlighted ? 'highlighted' : ''}`}>
        {t.highlighted && <div class="popular-badge">Most Popular</div>}
        <h4 class="tier-name">{t.name}</h4>
        <div class="tier-price">{t.price}</div>
        <p class="tier-target">{t.target}</p>
        <ul class="tier-features">
          {t.features.map((f) => (
            <li>{f}</li>
          ))}
        </ul>
        <div class="tier-cta">{t.cta}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .pricing-section {
    position: relative;
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: rgba(0, 2, 18, 0.4);
    border: 1px solid rgba(4, 163, 255, 0.25);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(4, 163, 255, 0.1);
    transition: all 0.3s ease;
  }

  .pricing-section:hover {
    border-color: rgba(4, 163, 255, 0.4);
  }

  .pricing-header {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(4, 163, 255, 0.2);
  }

  .pricing-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    background: linear-gradient(135deg, #04a3ff 0%, #00ced1 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .pricing-card {
    position: relative;
    padding: 1.5rem;
    background: rgba(0, 2, 18, 0.6);
    border: 1px solid rgba(4, 163, 255, 0.15);
    border-radius: 10px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    border-color: rgba(4, 163, 255, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 0 25px rgba(4, 163, 255, 0.15);
  }

  .pricing-card.highlighted {
    border-color: rgba(4, 163, 255, 0.5);
    background: rgba(4, 163, 255, 0.08);
    box-shadow:
      0 0 30px rgba(4, 163, 255, 0.2),
      0 8px 30px rgba(4, 163, 255, 0.1);
  }

  .pricing-card.highlighted::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    padding: 2px;
    background: linear-gradient(135deg, rgba(4, 163, 255, 0.6), rgba(0, 206, 209, 0.4), rgba(4, 163, 255, 0.6));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 10;
  }

  .popular-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 12px;
    background: linear-gradient(135deg, #04a3ff, #00ced1);
    color: #000212;
    border-radius: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 20;
  }

  .tier-name {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
  }

  .tier-price {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, #04a3ff 0%, #65ff00 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.25rem;
  }

  .tier-target {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tier-features li {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
    padding-left: 1.25rem;
    position: relative;
  }

  .tier-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: #65ff00;
    font-weight: 700;
  }

  .tier-cta {
    padding: 0.6rem;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: #04a3ff;
    border: 1px solid rgba(4, 163, 255, 0.3);
    border-radius: 8px;
    background: rgba(4, 163, 255, 0.05);
    transition: all 0.2s ease;
  }

  .highlighted .tier-cta {
    background: linear-gradient(135deg, #04a3ff, #00ced1);
    color: #000212;
    border: none;
  }

  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-card { transition: none; }
    .pricing-card:hover { transform: none; }
  }
</style>
