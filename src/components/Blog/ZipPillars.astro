---
/**
 * ZipPillars - Interactive 8-module security grid with glowing borders
 * Displays Zipminator's 8 security modules in a responsive 2x4 grid
 */
interface Module {
  name: string;
  icon: string;
  description: string;
  tech: string;
}

interface Props {
  title?: string;
}

const { title = "The 8 Security Pillars" } = Astro.props;

const modules: Module[] = [
  {
    name: 'PQC Messenger',
    icon: '💬',
    description: 'End-to-end encrypted messaging with PQ Double Ratchet protocol',
    tech: 'Kyber768 + X3DH',
  },
  {
    name: 'Quantum VoIP',
    icon: '📞',
    description: 'Voice and video calls with PQ-SRTP encryption',
    tech: 'ML-KEM + SRTP',
  },
  {
    name: 'Q-VPN',
    icon: '🛡️',
    description: 'Post-quantum VPN with automatic kill switch',
    tech: 'WireGuard + Kyber768',
  },
  {
    name: 'ZipBrowser',
    icon: '🌐',
    description: 'Privacy browser with PQC TLS inspection',
    tech: 'ML-KEM TLS 1.3',
  },
  {
    name: 'Quantum Mail',
    icon: '✉️',
    description: 'Self-destructing emails with PII scanning',
    tech: 'Kyber768 + DoD 5220.22-M',
  },
  {
    name: 'QRNG Engine',
    icon: '⚛️',
    description: '156-qubit IBM quantum random number generation',
    tech: 'IBM Marrakesh/Fez',
  },
  {
    name: 'PII Anonymizer',
    icon: '👁️',
    description: 'Automatic PII detection and redaction across 18 data types',
    tech: 'NLP + regex patterns',
  },
  {
    name: 'AI Assistant',
    icon: '🤖',
    description: 'Security-aware AI with quantum context awareness',
    tech: 'LLM + PQC awareness',
  },
];
---

<section class="pillars-section">
  <div class="pillars-header">
    <h3 class="pillars-title">{title}</h3>
    <span class="pillars-count">8 modules</span>
  </div>
  <div class="pillars-grid">
    {modules.map((mod) => (
      <div class="pillar-card">
        <div class="pillar-icon">{mod.icon}</div>
        <h4 class="pillar-name">{mod.name}</h4>
        <p class="pillar-desc">{mod.description}</p>
        <span class="pillar-tech">{mod.tech}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .pillars-section {
    position: relative;
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: rgba(0, 2, 18, 0.4);
    border: 1px solid rgba(4, 163, 255, 0.25);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(4, 163, 255, 0.1);
    transition: all 0.3s ease;
  }

  .pillars-section:hover {
    border-color: rgba(4, 163, 255, 0.4);
    box-shadow:
      0 0 25px rgba(4, 163, 255, 0.15),
      0 6px 30px rgba(4, 163, 255, 0.12);
  }

  .pillars-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(4, 163, 255, 0.2);
  }

  .pillars-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    background: linear-gradient(135deg, #04a3ff 0%, #00ced1 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    flex: 1;
  }

  .pillars-count {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    padding: 4px 10px;
    background: rgba(4, 163, 255, 0.1);
    border-radius: 12px;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .pillar-card {
    position: relative;
    padding: 1.25rem;
    background: rgba(0, 2, 18, 0.6);
    border: 1px solid rgba(4, 163, 255, 0.15);
    border-radius: 10px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pillar-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    padding: 2px;
    background: linear-gradient(
      135deg,
      rgba(4, 163, 255, 0.5),
      rgba(0, 206, 209, 0.3),
      rgba(4, 163, 255, 0.5)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 10;
  }

  .pillar-card:hover {
    border-color: rgba(4, 163, 255, 0.5);
    transform: translateY(-3px);
    box-shadow:
      0 0 30px rgba(4, 163, 255, 0.2),
      0 8px 30px rgba(4, 163, 255, 0.15);
  }

  .pillar-card:hover::before {
    opacity: 1;
  }

  .pillar-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .pillar-name {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
  }

  .pillar-desc {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    flex: 1;
  }

  .pillar-tech {
    display: inline-block;
    font-size: 0.75rem;
    padding: 3px 8px;
    background: linear-gradient(135deg, rgba(4, 163, 255, 0.15), rgba(0, 206, 209, 0.1));
    border: 1px solid rgba(4, 163, 255, 0.3);
    border-radius: 6px;
    color: #04a3ff;
    font-family: monospace;
    align-self: flex-start;
  }

  @media (max-width: 1024px) {
    .pillars-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pillar-card {
      transition: none;
    }
    .pillar-card:hover {
      transform: none;
    }
  }
</style>
