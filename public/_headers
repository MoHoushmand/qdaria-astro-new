/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # NOTE: CSP, X-Content-Type-Options, and Cache-Control are set in netlify.toml
  # They are NOT set here because Netlify's dev emulator applies public/_headers
  # to ALL requests (including Vite's internal /src/ and /node_modules/ module paths),
  # which breaks local development when nosniff and restrictive CSP are applied.

# Homepage - allow normal caching for better performance
/
  Cache-Control: public, max-age=3600, must-revalidate

# Clear HSTS endpoint
/clear-hsts
  Strict-Transport-Security: max-age=0; includeSubDomains
  Clear-Site-Data: "cache", "cookies", "storage", "executionContexts"
  Cache-Control: no-store, no-cache, must-revalidate, private
  Pragma: no-cache
  Expires: 0

# Redirect instructions page
/redirect-instructions.html
  Strict-Transport-Security: max-age=0; includeSubDomains
  Clear-Site-Data: "cache", "cookies", "storage"
  Cache-Control: no-store, no-cache, must-revalidate, private
  X-Robots-Tag: noindex, nofollow
